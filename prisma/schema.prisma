generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token             String?
  access_token              String?
  expires_at                Int?
  token_type                String?
  scope                     String?
  id_token                  String?
  session_state             String?
  refresh_token_expires_in  Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  sites         Site[]

  // SEO Tools settings backup (JSON snapshot of the browser-side keys/preferences), so
  // clearing the browser storage doesn't lose configured API keys. Accessed via raw SQL.
  seoSettings String?

  // Third-party API integrations
  neuralIndexerToken String?
  xmlRiverUserId     String?
  xmlRiverApiKey     String?
  twoIndexToken      String?

  // Custom Indexer Bot Farm
  indexerDomains      IndexerDomain[]
  indexerDictionaries IndexerDictionary[]

  // SEO Tools background generation jobs
  seoJobs             SeoJob[]

  // GEO Audits (how AI search engines perceive the brand/niche)
  geoAudits           GeoAudit[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Site {
  id        String   @id @default(cuid())
  userId    String
  url       String
  siteId    String   // GSC property root (sc-domain: or url)
  tags             String?  // JSON array string or comma separated
  brandedKeywords  String?  // JSON array e.g. ["ikea","ikea chair"]
  createdAt        DateTime @default(now())

  // Sitemap indexing
  sitemapUrl       String?   // custom sitemap URL (defaults to url + /sitemap.xml)
  crawlInterval    String?   // "disabled" | "daily" | "weekly" | "monthly"
  lastSitemapSync  DateTime?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics               DailyMetric[]
  contentGroups         ContentGroup[]
  topicClusters         TopicCluster[]
  pageInspections       PageInspection[]
  pageInspectionHistories PageInspectionHistory[]
  siteHealth            SiteHealth?
  sitemapUrls           SitemapUrl[]
  indexingOperations    IndexingOperation[]
  backlinks             Backlink[]
  claritySnapshots      ClaritySnapshot[]
  trackedKeywords       TrackedKeyword[]
  trackedQuestions      TrackedQuestion[]

  // Microsoft Clarity integration
  clarityToken          String?   // Data Export API token (per-project in Clarity)
  clarityProjectId      String?   // Clarity project ID (shown in Clarity dashboard URL)
  clarityInterval       String?   // auto-collect cadence: "disabled" | "daily"

  // Google Analytics 4 integration
  ga4PropertyId         String?   // GA4 numeric property ID (e.g. "123456789")
  ga4PropertyName       String?   // GA4 property display name (cached for UI)

  @@unique([userId, siteId])
}

model SitemapUrl {
  id            String    @id @default(cuid())
  siteId        String
  url           String

  // Google URL Inspection status
  googleStatus   String?   // "Submitted and indexed", "URL is not on Google", etc.
  googleCoverage String?   // raw coverage state
  googleReason   String?
  googleChecked  DateTime?

  // XML River check
  xrStatus      String?   // "indexed" | "not_indexed" | "error"
  xrChecked     DateTime?

  // 2index.ninja submission
  twoIndexStatus String?  // "submitted" | "not_submitted"
  twoIndexAt     DateTime?

  // NeuralIndexer submission
  neuralStatus   String?  // "submitted"
  neuralAt       DateTime?
  neuralQueue    String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  site          Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, url])
  @@index([siteId])
}

model Backlink {
  id            String    @id @default(cuid())
  siteId        String
  url           String    // the backlink URL (page that links to us)
  title         String?   // page title from 404-check crawl
  isAlive       Boolean?  // null = not checked; true = alive; false = dead/404
  aliveChecked  DateTime?
  xrStatus      String?   // "indexed" | "not_indexed" | "error"
  xrChecked     DateTime?
  twoIndexStatus String?  // "submitted"
  twoIndexAt    DateTime?
  addedAt       DateTime  @default(now())

  site          Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, url])
  @@index([siteId])
}

model IndexingOperation {
  id        String   @id @default(cuid())
  siteId    String
  urlCount  Int?     // how many URLs were affected
  type      String   // "sitemap_sync" | "google_check" | "xr_check" | "2index_submit" | "neural_submit"
  result    String?  // "success" | "error" | "partial"
  detail    String?  // JSON or text with extra info
  createdAt DateTime @default(now())

  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  @@index([siteId, createdAt])
}

model DailyMetric {
  id          String   @id @default(cuid())
  siteId      String
  date        DateTime
  url         String
  query       String
  clicks      Int
  impressions Int
  ctr         Float
  position    Float

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, date])
  @@index([url])
  @@index([query])
}

// ─── Rank Tracker (SERP position monitoring) ─────────────────────────────────
// Tracked keywords are checked daily by the in-app scheduler (rankScheduler) via the
// user's configured SERP provider (Serper.dev / DataForSEO — same keys as SEO Tools).
model TrackedKeyword {
  id            String    @id @default(cuid())
  siteId        String
  keyword       String
  device        String    @default("desktop") // reserved: "desktop" | "mobile"
  country       String    @default("us")      // gl code (2-letter)
  lang          String    @default("en")      // hl code
  createdAt     DateTime  @default(now())
  lastCheckedAt DateTime?

  // Denormalized latest state for cheap list rendering
  lastPosition  Int?      // null = not found in scanned depth
  prevPosition  Int?      // position from the previous check
  bestPosition  Int?
  lastUrl       String?   // ranking URL found on the last check

  site   Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  checks RankCheck[]

  @@unique([siteId, keyword, device, country])
  @@index([siteId])
  @@index([lastCheckedAt])
}

model RankCheck {
  id        String   @id @default(cuid())
  keywordId String
  checkedAt DateTime @default(now())
  position  Int?     // null = not found
  url       String?
  depth     Int?     // how many results were scanned
  error     String?

  keyword TrackedKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@index([keywordId, checkedAt])
}

// ─── AEO Tracker (AI answer-engine citation monitoring) ──────────────────────
// Tracked questions are checked periodically by the in-app scheduler (aeoScheduler) across
// multiple AI engines (ChatGPT, Perplexity, Claude, Grok) — same in-app-cron pattern as
// clarityScheduler/rankScheduler, no system cron needed. ChatGPT/Perplexity use live web
// search (a citation URL matching the site's domain is the strongest signal); Claude/Grok
// have no guaranteed browsing, so they fall back to text-mention matching.
model TrackedQuestion {
  id            String    @id @default(cuid())
  siteId        String
  question      String
  createdAt     DateTime  @default(now())
  lastCheckedAt DateTime?

  // Denormalized latest per-engine state for cheap list rendering — JSON:
  // { chatgpt: { cited, url, checkedAt }, perplexity: {...}, claude: {...}, grok: {...} }
  lastResults   String?

  site   Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  checks AeoCheck[]

  @@unique([siteId, question])
  @@index([siteId])
  @@index([lastCheckedAt])
}

model AeoCheck {
  id         String   @id @default(cuid())
  questionId String
  engine     String   // "chatgpt" | "perplexity" | "claude" | "grok"
  checkedAt  DateTime @default(now())
  cited      Boolean
  url        String?
  snippet    String?
  error      String?

  question TrackedQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@index([questionId, checkedAt])
}

model ContentGroup {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  rules     String   // JSON: [{type:"contains"|"equals", values:string[]}]
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model TopicCluster {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  rules     String   // JSON: [{type:"contains"|"equals", values:string[]}]
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model PageInspection {
  id          String   @id @default(cuid())
  siteId      String
  url         String
  status      String   // e.g. "Submitted and indexed"
  lastCrawl   DateTime?
  richResults String?
  lastInspect DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  @@unique([siteId, url])
}

model PageInspectionHistory {
  id          String   @id @default(cuid())
  siteId      String
  url         String
  date        DateTime
  status      String

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  @@unique([siteId, url, date])
}

// Microsoft Clarity — cached daily snapshots (API limit: 10 req/day, 3 days max)
model ClaritySnapshot {
  id          String   @id @default(cuid())
  siteId      String
  fetchedAt   DateTime @default(now())
  periodDays  Int      // 1, 2, or 3 — numOfDays sent to API
  data        String   // raw JSON from Clarity API

  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, fetchedAt])
}

model SiteHealth {
  id           String   @id @default(cuid())
  siteId       String   @unique
  checkedAt    DateTime @default(now())
  sslData      String?  // JSON: { valid, daysLeft, issuer, grade, error? }
  safeBrowsing String?  // JSON: { safe, threats?, error? }
  vitals       String?  // JSON: { lcp, fid, cls, ttfb, score, error? }
  virusTotal   String?  // JSON: { clean, malicious, suspicious, error? }

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

// ─── Custom Indexer Bot Farm Models ──────────────────────────────────────────

model IndexerDomain {
  id              String         @id @default(cuid())
  userId          String
  domain          String
  status          String         @default("active") // "active", "inactive", "expired"
  createdAt       DateTime       @default(now())
  apiKey          String         @default(cuid())
  template        String         @default("ecommerce")
  moneyUrl        String?
  allowedBots     String         @default("google,bing,yandex")
  pagesCount      Int            @default(0)
  subdomainsCount Int            @default(0)
  
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs            IndexerLog[]
  queue           IndexerQueue[]

  @@unique([userId, domain])
}

model IndexerLog {
  id        String        @id @default(cuid())
  domainId  String
  timestamp DateTime      @default(now())
  url       String
  ip        String
  userAgent String
  botType   String        // "google", "bing", "yandex", "other", "redirect"
  statusCode Int          @default(200)
  referer   String?

  domain    IndexerDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  @@index([domainId, timestamp])
}

model IndexerQueue {
  id        String        @id @default(cuid())
  domainId  String
  url       String
  status    String        @default("pending") // "pending", "crawled", "indexed"
  createdAt DateTime      @default(now())
  crawledAt DateTime?

  domain    IndexerDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  @@unique([domainId, url])
}

model IndexerDictionary {
  id        String        @id @default(cuid())
  userId    String
  word      String
  createdAt DateTime      @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, word])
}

// ─── SEO Tools — background generation jobs (outline / text / analysis) ──────────
// Lets a generation run server-side and persist its result, so the user can close
// the tab and pick the finished task up later from History.
model SeoJob {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "outline" | "text" | "analysis" | "landing"
  keyword   String   @default("")
  status    String   @default("processing") // "processing" | "completed" | "error"
  result    String?  // JSON string of the result (outline object / { text, ... } / report)
  error     String?
  meta      String?  // JSON string (tone, promptType, outlineId, factcheck/images flags…)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
}

// ─── SEO Tools knowledge base (Casino RAG) ─────────────────────────────────────
// Structured entity facts (slots, casinos) injected into outline/text generation.
// Populated by scripts/import-rag.ts from CSV exports; matched by normalized name.
model RagSlot {
  id         String  @id @default(cuid())
  name       String
  nameNorm   String  // lowercase, trimmed — for keyword containment matching
  provider   String  @default("")
  released   String  @default("")  // release date/year as text (source formats vary)
  slotType   String  @default("")  // "Видео слоты" / genre
  rtp        String  @default("")
  volatility String  @default("")
  maxWin     String  @default("")
  minBet     String  @default("")
  maxBet     String  @default("")
  layout     String  @default("")  // e.g. "5-3" reels x rows
  lines      String  @default("")
  features   String  @default("")  // comma-separated feature list
  themes     String  @default("")
  demoUrl    String  @default("")
  platform   String  @default("")
  source     String  @default("")  // "35k" | "demo"

  @@index([nameNorm])
  @@index([provider])
}

// Cached Ahrefs Domain Rating (free public API, 7-day TTL). Attribution required in UI:
// "Domain Rating by Ahrefs" → https://ahrefs.com/ (see ahrefs.com/legal/domain-rating-license).
model DrCache {
  domain    String   @id
  dr        Float
  checkedAt DateTime @default(now())
}

// ─── Link Monitor (Ahrefs API v3) — track fresh quality backlinks to watched brands ──
model LinkWatchBrand {
  id        String   @id @default(cuid())
  userId    String
  domain    String
  createdAt DateTime @default(now())

  @@unique([userId, domain])
}

model LinkMention {
  id         String   @id @default(cuid())
  userId     String
  brand      String   // watched brand domain
  urlFrom    String
  domainFrom String
  title      String   @default("")
  anchor     String   @default("")
  drFrom     Float    @default(0)
  firstSeen  String   @default("")
  urlTo      String   @default("")
  dofollow   Boolean  @default(true)
  fetchedAt  DateTime @default(now())

  @@index([userId, brand])
  @@index([userId, domainFrom])
}

model RagCasino {
  id          String @id @default(cuid())
  name        String
  nameNorm    String
  website     String @default("")
  country     String @default("")
  founded     String @default("")
  locality    String @default("")
  region      String @default("")
  size        String @default("")
  linkedinUrl String @default("")
  source      String @default("")

  @@index([nameNorm])
}

// ─── GEO Audit — how AI search engines (e.g. ChatGPT web search) perceive a niche ──
// A single run = one keyword/query analyzed with an agentic web-search model. We persist
// the raw search trace (batches, opened pages, citations) plus the derived analytics
// (brand leaderboard, trust signals, inclusion patterns) as one JSON `report`.
model GeoAudit {
  id        String   @id @default(cuid())
  userId    String
  query     String   @default("")  // the keyword / search query that was audited
  language  String   @default("en")
  country   String   @default("us")
  model     String   @default("")  // engine model used (e.g. "gpt-5")
  status    String   @default("processing") // "processing" | "completed" | "error"
  report    String?  // JSON string: full audit report (metrics + analytics + raw answer)
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
}
