generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token             String?
  access_token              String?
  expires_at                Int?
  token_type                String?
  scope                     String?
  id_token                  String?
  session_state             String?
  refresh_token_expires_in  Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  sites         Site[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Site {
  id        String   @id @default(cuid())
  userId    String
  url       String
  siteId    String   // GSC property root (sc-domain: or url)
  tags      String?  // JSON array string or comma separated
  createdAt DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics               DailyMetric[]
  contentGroups         ContentGroup[]
  topicClusters         TopicCluster[]
  pageInspections       PageInspection[]
  pageInspectionHistories PageInspectionHistory[]
  siteHealth            SiteHealth?

  @@unique([userId, siteId])
}

model DailyMetric {
  id          String   @id @default(cuid())
  siteId      String
  date        DateTime
  url         String
  query       String
  clicks      Int
  impressions Int
  ctr         Float
  position    Float

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, date])
  @@index([url])
  @@index([query])
}

model ContentGroup {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  rules     String   // JSON: [{type:"contains"|"equals", values:string[]}]
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model TopicCluster {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  rules     String   // JSON: [{type:"contains"|"equals", values:string[]}]
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model PageInspection {
  id          String   @id @default(cuid())
  siteId      String
  url         String
  status      String   // e.g. "Submitted and indexed"
  lastCrawl   DateTime?
  richResults String?
  lastInspect DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  @@unique([siteId, url])
}

model PageInspectionHistory {
  id          String   @id @default(cuid())
  siteId      String
  url         String
  date        DateTime
  status      String

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  @@unique([siteId, url, date])
}

model SiteHealth {
  id           String   @id @default(cuid())
  siteId       String   @unique
  checkedAt    DateTime @default(now())
  sslData      String?  // JSON: { valid, daysLeft, issuer, grade, error? }
  safeBrowsing String?  // JSON: { safe, threats?, error? }
  vitals       String?  // JSON: { lcp, fid, cls, ttfb, score, error? }
  virusTotal   String?  // JSON: { clean, malicious, suspicious, error? }

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
}
